APP_NAME=SmartBuyAgent
APP_ENV=development
HOST=0.0.0.0
PORT=8000
# SQLite fallback for local lightweight development.
DATABASE_URL=sqlite:///./data/smartbuy.db

# MySQL 5.7 compatible local example.
# DATABASE_URL=mysql+pymysql://smartbuy:smartbuy@127.0.0.1:3306/smartbuy_agent?charset=utf8mb4
# DATABASE_URL=mysql+pymysql://root:your_password@127.0.0.1:3306/smartbuy_agent?charset=utf8mb4

CHROMA_DIR=./data/chroma
LOG_LEVEL=INFO
REDIS_URL=redis://localhost:6379/0
SESSION_CACHE_TTL_SECONDS=1800
RETRIEVAL_PRODUCT_CACHE_TTL_SECONDS=600
RETRIEVAL_KNOWLEDGE_CACHE_TTL_SECONDS=1800
SSE_TRACE_TTL_SECONDS=1800
RATE_LIMIT_WINDOW_SECONDS=10
RATE_LIMIT_MAX_REQUESTS=5
FEEDBACK_CACHE_TTL_SECONDS=604800
EMBEDDING_PROVIDER=mock
EMBEDDING_DIM=32

# Real embedding provider example
# EMBEDDING_PROVIDER=openai_compatible
# EMBEDDING_API_BASE=https://your-embedding-api.example.com/v1
# EMBEDDING_API_KEY=your-api-key
# EMBEDDING_MODEL=your-embedding-model
# EMBEDDING_TIMEOUT_SECONDS=30

# LLM provider
LLM_PROVIDER=mock
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=mock-chat
LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOKENS=800
LLM_TEMPERATURE=0.2
